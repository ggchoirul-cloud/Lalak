# ============================================================
# TELEGRAM BOT
# ============================================================
BOT_TOKEN=isi_token_dari_botfather

# ============================================================
# GOMERCHANT API
# ============================================================
GO_MERCHANT_API_KEY=GO_xxxxxxxxxxxxx
GO_MERCHANT_SECRET=
# Nama project yang terdaftar di dashboard GoMerchant (WAJIB sesuai)
GO_MERCHANT_PROJECT=Avianto

# ============================================================
# PREMKU API (penyedia akun premium: Capcut, Netflix, dll)
# ============================================================
PREMKU_API_KEY=isi_api_key_premku_disini

# ============================================================
# DATABASE POSTGRESQL
# ============================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/telegram_auto_order

# ============================================================
# ADMIN
# ============================================================
# Daftar Telegram user ID admin, pisahkan dengan koma
ADMIN_IDS=123456789,987654321

# ============================================================
# BOT BEHAVIOR
# ============================================================
# Interval auto-check pembayaran (ms) — default 10 detik
PAYMENT_CHECK_INTERVAL=10000
# Lama waktu order sebelum expired (menit)
ORDER_EXPIRED_MINUTES=15

# Dashboard Admin
DASHBOARD_PORT=3000
DASHBOARD_TOKEN=admin123
